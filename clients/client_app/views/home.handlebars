<h2 class="section-title">Home</h2>
<div class="status-bar">
  <div class="status-item">
    User:
    <span class="muted">
      {{#if username}}
        <strong>{{username}}</strong>
      {{else}}
        <strong>Unknown</strong>
      {{/if}}
    </span>
    <div class="status-item">
      Agenda Token
      {{#if hasAgendaToken}}
        <span class="badge ok">Active</span>
      {{else}}
        <span class="badge off">Missing</span>
      {{/if}}
    </div>
  </div>
</div>

<div class="button-grid">
  <a class="btn" href="/agenda">Agenda</a>
</div>

<h3 class="section-title" style="margin-top: 22px;">Session Controls</h3>
<div class="button-grid">
  <a class="btn secondary" href="/logout-agenda">Logout Agenda</a>
</div>
