<!DOCTYPE html>
<html>
<head>
  <meta charset="utf-8">
  <title>Personal Organizer - Client App</title>
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
  <link href="https://fonts.googleapis.com/css2?family=DM+Sans:wght@400;600;700&display=swap" rel="stylesheet">
  <style>
    :root {
      --bg: #f4f7fb;
      --ink: #1b2330;
      --muted: #5b6677;
      --brand: #2f6fed;
      --brand-dark: #2356b9;
      --panel: #ffffff;
      --shadow: 0 12px 30px rgba(20, 35, 60, 0.12);
    }

    * {
      box-sizing: border-box;
    }

    body {
      margin: 0;
      font-family: "DM Sans", "Segoe UI", sans-serif;
      color: var(--ink);
      background:
        radial-gradient(1200px 400px at 20% -10%, #dfe8ff 0%, transparent 60%),
        radial-gradient(1200px 500px at 90% 0%, #f8e9ff 0%, transparent 60%),
        var(--bg);
      min-height: 100vh;
    }

    .page {
      max-width: 860px;
      margin: 0 auto;
      padding: 32px 20px 56px;
    }

    .banner {
      background: linear-gradient(120deg, #1e4acb 0%, #3f8cff 100%);
      color: #ffffff;
      border-radius: 18px;
      padding: 28px 32px;
      box-shadow: var(--shadow);
      margin-bottom: 28px;
    }

    .banner h1 {
      margin: 0;
      font-size: 28px;
      letter-spacing: 0.3px;
    }

    .panel {
      background: var(--panel);
      border-radius: 18px;
      padding: 26px 28px;
      box-shadow: var(--shadow);
    }

    .status-bar {
      display: flex;
      flex-wrap: wrap;
      gap: 12px 16px;
      align-items: center;
      padding: 14px 16px;
      background: #f5f8ff;
      border: 1px solid #dbe4f7;
      border-radius: 14px;
      margin-bottom: 18px;
    }

    .status-item {
      display: inline-flex;
      align-items: center;
      gap: 8px;
      font-weight: 600;
      color: var(--ink);
    }

    .badge {
      display: inline-flex;
      align-items: center;
      padding: 4px 10px;
      border-radius: 999px;
      font-size: 12px;
      font-weight: 700;
      letter-spacing: 0.3px;
      text-transform: uppercase;
    }

    .badge.ok {
      background: #e3f6ea;
      color: #1a7b43;
      border: 1px solid #bfe8cf;
    }

    .badge.off {
      background: #ffe9e5;
      color: #a7392a;
      border: 1px solid #ffc9c0;
    }

    .muted {
      color: var(--muted);
    }

    .button-grid {
      display: flex;
      flex-wrap: wrap;
      gap: 12px;
      margin-top: 16px;
    }

    .btn {
      display: inline-flex;
      align-items: center;
      justify-content: center;
      padding: 12px 18px;
      border-radius: 12px;
      border: 1px solid transparent;
      background: var(--brand);
      color: #ffffff;
      font-weight: 600;
      text-decoration: none;
      box-shadow: 0 8px 16px rgba(47, 111, 237, 0.25);
      transition: transform 0.15s ease, box-shadow 0.15s ease, background 0.15s ease;
    }

    .btn:hover {
      background: var(--brand-dark);
      transform: translateY(-1px);
      box-shadow: 0 10px 18px rgba(47, 111, 237, 0.3);
    }

    .btn.secondary {
      background: #ffffff;
      color: var(--ink);
      border-color: #d7deea;
      box-shadow: 0 8px 16px rgba(20, 35, 60, 0.08);
    }

    .btn.secondary:hover {
      background: #f0f4ff;
    }

    .section-title {
      margin: 0 0 8px;
      font-size: 18px;
    }

    .section-spacer {
      margin-top: 22px;
    }

    ul {
      padding-left: 18px;
    }

    a.link {
      color: var(--brand);
      text-decoration: none;
      font-weight: 600;
    }
  </style>
</head>
<body>
  <div class="page">
    <header class="banner">
      <h1>Personal Organizer - Client App</h1>
    </header>
    <main class="panel">
      {{{body}}}
    </main>
  </div>
</body>
</html>
